# ============================================================
# SmsVerifyKit 配置文件（新手只需改这个文件）
# 用法：复制为 .env → 填下面 3 项必填 → 运行 bash scripts/setup.sh 测试
# ============================================================

# 【必填】阿里云 RAM 用户的 AccessKey（勿泄露、勿提交 Git）
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=

# 【必填】短信签名 — 开通短信认证后，在控制台看到的系统签名
# 常见值：速通互联验证码（以你控制台显示的为准）
SMS_SIGN_NAME=速通互联验证码

# 【可选】一般不用改
SMS_ENDPOINT=https://dypnsapi.aliyuncs.com
SMS_COUNTRY_CODE=86
SMS_CODE_LENGTH=4
SMS_VALID_SECONDS=300
SMS_INTERVAL_SECONDS=60

# 【可选】HTTP 网关 API 密钥（部署 gateway 时建议设置）
SMS_GATEWAY_API_KEY=

# 【可选】场景模板 CODE（开通后默认即可用）
SMS_TPL_LOGIN=100001
SMS_TPL_REGISTER=100001
SMS_TPL_BIND=100004
SMS_TPL_CHANGE=100002
